{
  "manifest_version": 3,
  "name": "Safe Guard",
  "description": "Integracao local entre navegador e API do Safe Guard",
  "version": "0.1.0",
  "permissions": ["storage", "tabs", "activeTab", "clipboardWrite", "scripting"],
  "host_permissions": ["http://127.0.0.1:5474/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+1",
        "mac": "Command+Shift+1"
      },
      "description": "Abrir o popup da extensao"
    },
    "autofill-first-entry": {
      "suggested_key": {
        "default": "Ctrl+Shift+2",
        "mac": "Command+Shift+2"
      },
      "description": "Autofill da primeira credencial salva"
    },
    "lock-session": {
      "suggested_key": {
        "default": "Ctrl+Shift+3",
        "mac": "Command+Shift+3"
      },
      "description": "Bloquear a sessao da extensao"
    }
  },
  "action": {
    "default_title": "Safe Guard",
    "default_popup": "popup.html",
    "default_icon": {
      "512": "icons/logo/logo-safe-guard.png"
    }
  },
  "icons": {
    "512": "icons/logo/logo-safe-guard.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
